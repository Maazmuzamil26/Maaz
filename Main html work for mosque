<script>
/* ===== Dark Mode ===== */
let dark=localStorage.getItem("dark")==="true";
document.body.classList.toggle("dark",dark);
function toggleDarkMode(){dark=!dark;document.body.classList.toggle("dark",dark);localStorage.setItem("dark",dark)}

/* ===== Language Switch ===== */
let langs=["en","ar","ur"],langIndex=0;
function toggleLanguage(){
  langIndex = (langIndex + 1) % langs.length;
  let lang = langs[langIndex];

  document.documentElement.lang = lang;
  document.body.dir = (lang === "ar" || lang === "ur") ? "rtl" : "ltr";

  document.querySelectorAll("[data-en]").forEach(el=>{
    if(el.dataset[lang]){
      el.textContent = el.dataset[lang];
    }
  });
}
/* ===== Tabs ===== */
function showSection(id){

  // Hide ALL sections everywhere
  document.querySelectorAll("section").forEach(sec=>{
    sec.classList.remove("active");
  });

  // Show selected one
  const selected = document.getElementById(id);
  if(selected){
    selected.classList.add("active");
    window.scrollTo({ top: 0, behavior: "smooth" });
  }
}
/* ============================= */
/* 🔐 IMPROVED ADMIN SYSTEM */
/* ============================= */

const ADMIN_HASH = "454fc0c07dacbbe6874d2eb821d2ecd87046bb9496c5f8e90b5fc66d370f7ae8";

let adminLoggedIn = localStorage.getItem("adminLoggedIn") === "true";
let editMode = false;

async function hashText(text){
  const encoder = new TextEncoder();
  const data = encoder.encode(text);
  const hashBuffer = await crypto.subtle.digest("SHA-256", data);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(b => b.toString(16).padStart(2, "0")).join("");
}

/* ===== LOGIN ===== */
async function adminLogin(){
  const input = document.getElementById("adminPinInput").value;
  const hashedInput = await hashText(input);

  if(hashedInput === ADMIN_HASH){
    localStorage.setItem("adminLoggedIn","true");
    adminLoggedIn = true;
    showAdminPanel();
    showToast("Admin logged in!");
  } else {
    showToast("Incorrect PIN");
  }
}

function adminLogout(){
  disableEditMode();
  localStorage.removeItem("adminLoggedIn");
  adminLoggedIn = false;
  document.getElementById("adminPanel").style.display="none";
  document.getElementById("loginBox").style.display="block";
  showToast("Logged out!");
}

function showAdminPanel(){
  if(adminLoggedIn){
    document.getElementById("loginBox").style.display="none";
    document.getElementById("adminPanel").style.display="block";
  }
}

/* ============================= */
/* ✏️ SAFE EDIT MODE */
/* ============================= */

function enableEditMode(){
  if(!adminLoggedIn) return;

  const area = document.getElementById("contentArea");

  editMode = true;
  document.querySelectorAll("#contentArea h2, #contentArea h3, #contentArea p, #contentArea li")
  .forEach(el => el.contentEditable = "true");
  area.style.outline = "2px dashed #046d4a";

  disableProtectedElements(true);

  showToast("Edit mode enabled");
}

function disableEditMode(){
  const area = document.getElementById("contentArea");

  editMode = false;
  area.contentEditable = "false";
  area.style.outline = "none";

  disableProtectedElements(false);
}

function disableProtectedElements(disable){
  document.querySelectorAll("button, input, select, .nav-bar").forEach(el=>{
    if(!el.closest("#adminPanel")){
      el.contentEditable = "false";
    }
  });
}

/* ===== SAVE ===== */
function saveContent(){
  const area = document.getElementById("contentArea");
  localStorage.setItem("savedContent", area.innerHTML);
  disableEditMode();
  showToast("Changes saved!");
}

/* ===== RESTORE DEFAULT ===== */
function restoreDefault(){
  if(confirm("Restore original content? This cannot be undone.")){
    localStorage.removeItem("savedContent");
    location.reload();
  }
}

/* ===== LOAD CONTENT ===== */
function loadSavedContent(){
  const saved = localStorage.getItem("savedContent");
  if(saved){
    document.getElementById("contentArea").innerHTML = saved;
  }
}

/* ===== AUTO LOGIN CHECK ===== */
/* ===== Toast ===== */
function showToast(msg){
  let t = document.getElementById("toast");
  if(!t){
    t = document.createElement("div");
    t.id = "toast";
    t.className = "toast";
    document.body.appendChild(t);
  }
  t.innerText = msg;
  t.style.display = "block";
  setTimeout(()=>t.style.display="none",3000);
}

/* ===== Registration Modal ===== */
const modal=document.createElement("div"); // placeholder, modal already in HTML

function openModal(){document.getElementById("modal").style.display="flex"}
function closeModal(){document.getElementById("modal").style.display="none";resetForm()}

/* ===== Form Handling ===== */
const form=document.getElementById("registerForm");
if(form){
  form.addEventListener("submit",e=>{
    e.preventDefault();
    let data=new FormData(form);
    let name=data.get("name").trim();
    let age=parseInt(data.get("age"));
    let phone=data.get("phone").trim();
    let level=data.get("level");
    if(name.length<3)return showToast("Invalid name");
    if(age<3||age>80)return showToast("Invalid age");
    if(!/^[0-9+\-\s()]+$/.test(phone))return showToast("Invalid phone");
    if(!level)return showToast("Select level"); 
    let regs=JSON.parse(localStorage.getItem("regs")||"[]");
    regs.push({name,age,phone,level});
    localStorage.setItem("regs",JSON.stringify(regs));
    form.style.display="none";
    document.getElementById("thankYou").style.display="block";
    showToast("Registered successfully");
  });
}

function resetForm(){form.reset();form.style.display="block";document.getElementById("thankYou").style.display="none"}

function saveProgress(){
  let name = document.getElementById("studentName").value;
  let mem = document.getElementById("memorisation").value;
  let att = document.getElementById("attendance").value;

  if(!name) return showToast("Enter student name");

  let list = JSON.parse(localStorage.getItem("progressData")||"[]");
  list.push({name,mem,att});
  localStorage.setItem("progressData",JSON.stringify(list));

  displayProgress();
  showToast("Progress saved");
}

function displayProgress(){
  let data = JSON.parse(localStorage.getItem("progressData")||"[]");
  let container = document.getElementById("progressList");
  container.innerHTML = "";
  data.forEach(s=>{
    container.innerHTML += `<div class="card">
      <strong>${s.name}</strong><br>
      Surahs: ${s.mem}<br>
      Attendance: ${s.att}
    </div>`;
  });
}

window.addEventListener("load",displayProgress);
function generateCertificate(){
  let name = document.getElementById("studentName").value;
  if(!name) return showToast("Enter student name");

  let win = window.open();
  win.document.write(`
    <h1 style="text-align:center">Certificate of Completion</h1>
    <p style="text-align:center">This certifies that</p>
    <h2 style="text-align:center">${name}</h2>
    <p style="text-align:center">has successfully completed their level at Umar Masjid Madrassah.</p>
  `);
  win.print();
}

window.addEventListener("DOMContentLoaded", () => {
  loadSavedContent();
  showAdminPanel();
  displayProgress();
  showSection("home");
});
</script>

